{
  "name": "sanity-studio-template",
  "private": true,
  "version": "1.0.0",
  "main": "package.json",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.34.5+sha512.a4ee05f2f73658255bd6a89859c065a45c28a57daefae2c893a168ee2b73168c37b91e83e57ea67654ad03f03031746430e8bce38e362e042605fb8abc80192e",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.34.5"
  },
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "deploy-graphql": "sanity graphql deploy",
    "lint": "biome check . && eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "node --test",
    "check:downstream-sync": "node scripts/check-downstream-sync.mjs",
    "test:downstream-sync": "node --test scripts/check-downstream-sync.test.mjs",
    "check": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && sanity build && corepack pnpm audit --audit-level low",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@jessepomeroy/print-catalog": "^0.2.0",
    "@sanity/icons": "^3.7.4",
    "@sanity/orderable-document-list": "^1.5.1",
    "@sanity/presentation": "^2.0.0",
    "@sanity/ui": "^3.1.14",
    "@sanity/vision": "^5.31.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sanity": "^5.31.1",
    "sanity-plugin-documents-pane": "^3.0.2",
    "sanity-plugin-media": "^4.2.0",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "semi": false,
    "printWidth": 100,
    "bracketSpacing": false,
    "singleQuote": true
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx}": [
      "eslint --max-warnings=0"
    ]
  },
  "pnpm": {
    "overrides": {
      "@babel/core@<=7.29.0": "7.29.6",
      "@babel/plugin-transform-modules-systemjs@>=7.12.0 <=7.29.3": "7.29.4",
      "@sanity/uuid@3.0.2": "3.0.3",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
      "dompurify@<=3.4.10": "3.4.11",
      "esbuild@>=0.27.3 <0.28.1": "0.28.1",
      "flatted@<=3.4.1": "3.4.2",
      "form-data@>=4.0.0 <4.0.6": "4.0.6",
      "js-yaml@>=4.0.0 <=4.1.1": "4.2.0",
      "js-yaml@4.1.1": "4.2.0",
      "prismjs@<1.30.0": "1.30.0",
      "js-yaml@<3.15.0": "3.15.0",
      "json-2-csv@>=3.15.0 <5.5.11": "5.5.11",
      "linkify-it@<=5.0.0": "5.0.1",
      "markdown-it@<=14.1.1": "14.2.0",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "picomatch@<2.3.2": "2.3.2",
      "postcss@<8.5.10": "8.5.10",
      "tar@<=7.5.15": "7.5.16",
      "undici@<6.27.0": "6.27.0",
      "undici@>=7.0.0 <7.28.0": "7.28.0",
      "uuid@11.1.0": "11.1.1",
      "uuid@10.0.0": "11.1.1",
      "uuid@13.0.0": "13.0.1",
      "vite@>=7.0.0 <=7.3.4": "7.3.6",
      "ws@>=8.0.0 <8.21.0": "8.21.0"
